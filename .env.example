# Local development and Docker Compose demo settings. Do not use unchanged in a
# public deployment.
OPENROUTER_API_KEY=your-openrouter-api-key
# Remote or hosted Qdrant endpoint. Docker Compose does not start local Qdrant.
QdrantURL=https://your-qdrant-cluster-url
QdrantApiKey=your-qdrant-api-key
DEEP_SEEK = "TEST"
MEDIC_QDRANT_COLLECTION=hybrid_medic_demo_documents
MEDIC_EVAL_QDRANT_PREFIX=medic_eval
MEDIC_EVAL_JUDGE_MODEL=openai/gpt-4.1-mini
MEDIC_EVAL_EMBEDDING_MODEL=openai/text-embedding-3-small
LANGFUSE_PUBLIC_KEY=pk-lf-your-project-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=evaluation
MEDIC_LANGFUSE_TRACING_ENABLED=false
MEDIC_LANGFUSE_ENVIRONMENT=development
MEDIC_LANGFUSE_SAMPLE_RATE=1.0
# Keep disabled unless sending medical prompt/response content is explicitly approved.
MEDIC_LANGFUSE_CAPTURE_CONTENT=false

# PostgreSQL for local CLI usage. Docker Compose overrides this inside the app container.
MEDIC_DATABASE_URL=postgresql+psycopg://medic:medic@127.0.0.1:5432/medic

# Dashboard auth
MEDIC_DASHBOARD_USERNAME=admin
MEDIC_DASHBOARD_PASSWORD=change-me
MEDIC_SESSION_SECRET=replace-with-a-long-random-secret
MEDIC_DASHBOARD_COOKIE_SECURE=false
